<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>MultiMatch — Find the best price. Track every order.</title>
<meta name="description" content="Search across major retailers to compare prices, ratings, and delivery. Track all your online orders in one place. Coming soon.">
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Syne:wght@500;600;700;800&family=DM+Sans:wght@300;400;500;600;700&display=swap" rel="stylesheet">
<style>
:root {
  --bg: #08080f;
  --surface: #0e0e18;
  --surface2: #161625;
  --border: #222235;
  --border2: #2e2e48;
  --accent: #00e5a0;
  --accent2: #7c6dfa;
  --accent3: #ff6b6b;
  --text: #eeeef8;
  --text2: #b0b0cc;
  --muted: #7b7b96;
  --radius: 14px;
  --radius-sm: 10px;
  --transition: 0.25s cubic-bezier(0.4, 0, 0.2, 1);
}
* { margin: 0; padding: 0; box-sizing: border-box; }
html { scroll-behavior: smooth; }
body {
  font-family: 'DM Sans', sans-serif;
  background: var(--bg);
  color: var(--text);
  line-height: 1.5;
  -webkit-font-smoothing: antialiased;
  overflow-x: hidden;
}
a { color: inherit; text-decoration: none; }
.container { max-width: 1100px; margin: 0 auto; padding: 0 24px; }

/* Nav */
nav {
  position: fixed; top: 0; left: 0; right: 0; z-index: 100;
  background: rgba(8,8,15,0.85); backdrop-filter: blur(20px);
  -webkit-backdrop-filter: blur(20px);
  border-bottom: 1px solid var(--border);
  padding: 0 24px; height: 64px;
  display: flex; align-items: center; justify-content: space-between;
}
.logo {
  display: flex; align-items: center; gap: 10px;
  font-family: 'Syne', sans-serif; font-weight: 800; font-size: 1.2rem;
  letter-spacing: -0.02em;
}
.logo-mark {
  width: 34px; height: 34px;
  background: linear-gradient(135deg, var(--accent), var(--accent2));
  border-radius: 9px; display: flex; align-items: center; justify-content: center;
  font-size: 16px; box-shadow: 0 4px 16px rgba(0,229,160,0.25);
}
.logo em { font-style: normal; color: var(--accent); }
.nav-cta {
  background: var(--accent); color: #000; border: none;
  font-family: 'Syne', sans-serif; font-weight: 700; font-size: 0.82rem;
  padding: 10px 18px; border-radius: 25px; cursor: pointer;
  transition: var(--transition); letter-spacing: -0.01em;
}
.nav-cta:hover { box-shadow: 0 4px 20px rgba(0,229,160,0.3); transform: translateY(-1px); }

/* Hero */
.hero {
  padding: 140px 0 80px; text-align: center; position: relative;
  overflow: hidden;
}
.hero::before {
  content: ''; position: absolute; top: -200px; left: 50%; transform: translateX(-50%);
  width: 600px; height: 600px;
  background: radial-gradient(circle, rgba(0,229,160,0.06) 0%, transparent 70%);
  pointer-events: none;
}
.hero-badge {
  display: inline-flex; align-items: center; gap: 6px;
  background: var(--accent-dim, rgba(0,229,160,0.12));
  border: 1px solid rgba(0,229,160,0.2);
  border-radius: 25px; padding: 6px 14px;
  font-size: 0.75rem; font-weight: 700; color: var(--accent);
  letter-spacing: 0.06em; text-transform: uppercase; margin-bottom: 24px;
}
.hero h1 {
  font-family: 'Syne', sans-serif; font-weight: 800; font-size: clamp(2.2rem, 5vw, 3.4rem);
  line-height: 1.1; letter-spacing: -0.03em; margin-bottom: 20px;
}
.hero h1 em {
  font-style: normal;
  background: linear-gradient(90deg, var(--accent), var(--accent2));
  -webkit-background-clip: text; -webkit-text-fill-color: transparent;
  background-clip: text;
}
.hero p {
  font-size: 1.1rem; color: var(--text2); max-width: 560px;
  margin: 0 auto 36px; line-height: 1.6;
}
.email-form {
  display: flex; gap: 10px; max-width: 460px; margin: 0 auto;
  flex-wrap: wrap; justify-content: center;
}
.email-form input {
  flex: 1; min-width: 240px;
  background: var(--surface2); border: 1px solid var(--border);
  border-radius: 30px; color: var(--text); font-size: 0.95rem;
  padding: 14px 20px; outline: none; transition: var(--transition);
}
.email-form input:focus { border-color: var(--accent); box-shadow: 0 0 0 3px rgba(0,229,160,0.1); }
.email-form input::placeholder { color: var(--muted); }
.email-form button {
  background: linear-gradient(135deg, var(--accent), #00c896);
  color: #000; border: none; font-family: 'Syne', sans-serif;
  font-weight: 700; font-size: 0.95rem; padding: 14px 28px;
  border-radius: 30px; cursor: pointer; transition: var(--transition);
  white-space: nowrap;
}
.email-form button:hover { box-shadow: 0 6px 24px rgba(0,229,160,0.3); }
.email-form button:disabled { opacity: 0.6; cursor: not-allowed; }

/* Features */
.features {
  padding: 80px 0; position: relative;
}
.section-label {
  text-align: center; font-size: 0.75rem; text-transform: uppercase;
  letter-spacing: 0.12em; color: var(--accent); font-weight: 700; margin-bottom: 12px;
}
.section-title {
  text-align: center; font-family: 'Syne', sans-serif; font-weight: 700;
  font-size: 2rem; letter-spacing: -0.02em; margin-bottom: 48px;
}
.feature-grid {
  display: grid; grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
  gap: 20px;
}
.feature-card {
  background: var(--surface); border: 1px solid var(--border);
  border-radius: var(--radius); padding: 28px;
  transition: var(--transition); position: relative; overflow: hidden;
}
.feature-card:hover { border-color: var(--border2); transform: translateY(-2px); }
.feature-icon {
  width: 48px; height: 48px; border-radius: 12px;
  display: flex; align-items: center; justify-content: center;
  font-size: 1.4rem; margin-bottom: 18px;
}
.feature-icon.green { background: rgba(0,229,160,0.12); }
.feature-icon.purple { background: rgba(124,109,250,0.12); }
.feature-icon.red { background: rgba(255,107,107,0.12); }
.feature-card h3 {
  font-family: 'Syne', sans-serif; font-weight: 700; font-size: 1.05rem;
  margin-bottom: 8px;
}
.feature-card p { font-size: 0.9rem; color: var(--muted); line-height: 1.6; }

/* How It Works */
.how { padding: 80px 0; }
.steps {
  display: grid; grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
  gap: 16px; margin-top: 48px;
}
.step {
  text-align: center; padding: 24px 16px;
}
.step-num {
  width: 40px; height: 40px; margin: 0 auto 16px;
  background: linear-gradient(135deg, var(--accent2), var(--accent));
  border-radius: 10px; display: flex; align-items: center; justify-content: center;
  font-family: 'Syne', sans-serif; font-weight: 800; font-size: 1rem; color: #fff;
}
.step h4 { font-family: 'Syne', sans-serif; font-weight: 700; margin-bottom: 6px; }
.step p { font-size: 0.85rem; color: var(--muted); line-height: 1.5; }

/* CTA */
.cta {
  padding: 80px 0; text-align: center;
  background: linear-gradient(180deg, transparent, rgba(0,229,160,0.03), transparent);
}
.cta h2 {
  font-family: 'Syne', sans-serif; font-weight: 800; font-size: 2rem;
  letter-spacing: -0.02em; margin-bottom: 16px;
}
.cta p { color: var(--text2); margin-bottom: 32px; font-size: 1rem; }

/* Footer */
footer {
  border-top: 1px solid var(--border); padding: 40px 0;
  font-size: 0.82rem; color: var(--muted); text-align: center;
}
.footer-links { display: flex; gap: 20px; justify-content: center; flex-wrap: wrap; margin-bottom: 16px; }
.footer-links a { transition: var(--transition); }
.footer-links a:hover { color: var(--text); }
.disclosure {
  background: rgba(124,109,250,0.06); border: 1px solid rgba(124,109,250,0.15);
  border-radius: var(--radius-sm); padding: 14px 18px; max-width: 700px;
  margin: 0 auto 16px; font-size: 0.78rem; line-height: 1.6;
}

/* Toast */
.toast {
  position: fixed; bottom: 30px; left: 50%; transform: translateX(-50%) translateY(20px);
  background: var(--surface); border: 1px solid var(--border2);
  color: var(--accent); padding: 12px 24px; border-radius: 30px;
  font-weight: 600; font-size: 0.9rem; z-index: 999;
  opacity: 0; transition: var(--transition); pointer-events: none;
}
.toast.show { opacity: 1; transform: translateX(-50%) translateY(0); }

@media (max-width: 600px) {
  .hero { padding: 120px 0 60px; }
  .email-form { flex-direction: column; align-items: center; }
  .email-form input, .email-form button { width: 100%; }
  .nav-cta { font-size: 0.75rem; padding: 8px 14px; }
}
</style>
</head>
<body>

<nav aria-label="Main navigation">
  <a href="#" class="logo">
    <span class="logo-mark" aria-hidden="true">◎</span>
    <span>Multi<em>Match</em></span>
  </a>
  <button class="nav-cta" onclick="document.getElementById('emailInput').focus()">Get early access</button>
</nav>

<section class="hero">
  <div class="container">
    <div class="hero-badge">Coming soon</div>
    <h1>Find the best price.<br><em>Track every order.</em></h1>
    <p>Search across Amazon, eBay, JB Hi-Fi and more to compare prices, ratings, and delivery speed. Then track all your orders in one dashboard — automatically.</p>
    <form class="email-form" id="emailForm">
      <input type="email" id="emailInput" placeholder="Enter your email for early access" required aria-label="Email address">
      <button type="submit" id="submitBtn">Join the waitlist</button>
    </form>
  </div>
</section>

<section class="features" id="features">
  <div class="container">
    <div class="section-label">Features</div>
    <h2 class="section-title">Everything in one place</h2>
    <div class="feature-grid">
      <div class="feature-card">
        <div class="feature-icon green">🔍</div>
        <h3>Multi-retailer search</h3>
        <p>Search once, compare results from all major retailers side by side. Prices, ratings, delivery times — all in one view.</p>
      </div>
      <div class="feature-card">
        <div class="feature-icon purple">📦</div>
        <h3>Unified order tracking</h3>
        <p>Connect your email and we automatically find every order confirmation. See what's shipped, what's delayed, and what's arriving today.</p>
      </div>
      <div class="feature-card">
        <div class="feature-icon red">💰</div>
        <h3>Price drop alerts</h3>
        <p>Set alerts on products you want. We'll notify you the moment the price drops — even on items you already bought.</p>
      </div>
      <div class="feature-card">
        <div class="feature-icon purple">📸</div>
        <h3>Photo & barcode search</h3>
        <p>Snap a photo or scan a barcode in-store to instantly compare prices online before you buy.</p>
      </div>
      <div class="feature-card">
        <div class="feature-icon green">📊</div>
        <h3>Spend insights</h3>
        <p>Understand your shopping habits with clean monthly breakdowns by retailer, category, and delivery performance.</p>
      </div>
      <div class="feature-card">
        <div class="feature-icon red">🔄</div>
        <h3>One-click reorder</h3>
        <p>Running low on something? Reorder from your purchase history with a single tap. We find the best current price.</p>
      </div>
    </div>
  </div>
</section>

<section class="how">
  <div class="container">
    <div class="section-label">How it works</div>
    <h2 class="section-title">Three simple steps</h2>
    <div class="steps">
      <div class="step">
        <div class="step-num">1</div>
        <h4>Search or scan</h4>
        <p>Type a product name, upload a photo, or scan a barcode to start comparing.</p>
      </div>
      <div class="step">
        <div class="step-num">2</div>
        <h4>Compare & buy</h4>
        <p>See prices, ratings, and delivery times across retailers. Pick the best deal.</p>
      </div>
      <div class="step">
        <div class="step-num">3</div>
        <h4>Track everything</h4>
        <p>Your orders appear automatically. Know exactly when every package arrives.</p>
      </div>
    </div>
  </div>
</section>

<section class="cta">
  <div class="container">
    <h2>Be the first to try MultiMatch</h2>
    <p>Join the waitlist for early access and shape the features we build first.</p>
    <form class="email-form" id="emailForm2">
      <input type="email" placeholder="Your email address" required aria-label="Email address">
      <button type="submit">Join the waitlist</button>
    </form>
  </div>
</section>

<footer>
  <div class="container">
    <div class="disclosure">
      <strong>Disclosure:</strong> MultiMatch may earn a commission when you make a purchase through our links, at no extra cost to you. This does not affect our rankings — we always show you the genuinely best deal first.
    </div>
    <div class="footer-links">
      <a href="#">Privacy Policy</a>
      <a href="#">Terms of Service</a>
      <a href="#">How We Make Money</a>
      <a href="mailto:hello@multimatch.online">Contact</a>
    </div>
    <p>&copy; 2026 MultiMatch. All rights reserved.</p>
  </div>
</footer>

<div class="toast" id="toast" role="status" aria-live="polite"></div>

<script>
document.querySelectorAll('.email-form').forEach(form => {
  form.addEventListener('submit', async (e) => {
    e.preventDefault();
    const input = form.querySelector('input[type="email"]');
    const btn = form.querySelector('button');
    const email = input.value.trim();
    
    if (!email || !email.includes('@')) {
      showToast('Please enter a valid email address');
      return;
    }
    
    btn.disabled = true;
    btn.textContent = 'Sending...';
    
    // Simulate API call — replace with your actual endpoint
    await new Promise(r => setTimeout(r, 800));
    
    btn.textContent = 'You\'re on the list! ✓';
    input.value = '';
    showToast('Welcome to the waitlist! 🎉');
    
    setTimeout(() => {
      btn.disabled = false;
      btn.textContent = 'Join the waitlist';
    }, 3000);
  });
});

function showToast(msg) {
  const toast = document.getElementById('toast');
  toast.textContent = msg;
  toast.classList.add('show');
  clearTimeout(toast._t);
  toast._t = setTimeout(() => toast.classList.remove('show'), 3000);
}

// Smooth scroll for older browsers
document.querySelectorAll('a[href^="#"]').forEach(a => {
  a.addEventListener('click', e => {
    const target = document.querySelector(a.getAttribute('href'));
    if (target) { e.preventDefault(); target.scrollIntoView({ behavior: 'smooth' }); }
  });
});
</script>
</body>
</html>
